{
    "compilerOptions": {
        "types": ["node"],
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["ES2024", "ESNext.Array"],
        "noImplicitAny": false,
        "noEmitOnError": true,
        "sourceMap": true,
        "preserveConstEnums": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "strictNullChecks": true,
        "skipLibCheck": true,
        "allowJs": true,
        "rootDir": "./src",
        "outDir": "build",
        "useUnknownInCatchVariables": false,
        "pretty": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*.js",
        "src/**/*.ts",
        "src/index.ts"  ],
    "exclude": [
        "node_modules",
        "src/**/*_test.ts",
        "src/**/*.test.ts",
        "src/__mocks__/**",
        "src/test/**/*.ts"
    ]
  }